{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "sqlotter",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Post Daily Splot! Puzzle",
        "description": "Generate and post today's daily Splot! puzzle",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-daily"
      },
      {
        "label": "Create Splot! Post",
        "description": "Post a new Splot! game post to this subreddit",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "scheduler": {
    "tasks": {
      "daily-puzzle": {
        "endpoint": "/internal/scheduler/daily-puzzle",
        "cron": "0 8 * * *"
      }
    }
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  }
}
