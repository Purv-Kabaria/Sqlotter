{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "sqlotter",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "media": true
  },
  "menu": {
    "items": [
      {
        "label": "Post Daily Sqlotter Puzzle",
        "description": "Generate and post today's daily Sqlotter puzzle",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-daily"
      },
      {
        "label": "Create Sqlotter Post",
        "description": "Post a new Sqlotter game post to this subreddit",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "Reset All Level Statistics",
        "description": "Wipe every user's level completion/stars and all leaderboards (sparks and shop items are untouched)",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/reset-level-stats"
      },
      {
        "label": "Reset ALL User Data & Progress",
        "description": "Full wipe: every user's sparks, shop items, completions, streaks, and all leaderboards",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/reset-all-users"
      }
    ]
  },
  "scheduler": {
    "tasks": {
      "daily-puzzle": {
        "endpoint": "/internal/scheduler/daily-puzzle",
        "cron": "0 * * * *"
      },
      "fitcheck-post": {
        "endpoint": "/internal/scheduler/fitcheck-post",
        "cron": "0 15 * * 5"
      },
      "fitcheck-award": {
        "endpoint": "/internal/scheduler/fitcheck-award",
        "cron": "0 0 * * 1"
      }
    }
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onAppUpgrade": "/internal/triggers/on-app-upgrade"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "dev": {
    "subreddit": "sqlotter_dev"
  }
}